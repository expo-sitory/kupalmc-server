                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 2 [&aIllonggo&f] Activated." to player
                    stop   
                      
                else if player has permission "ethnicity.slot-2.aklanon":
                    execute console command "lp user %player% parent add aklanon"
                    execute console command "lp user %player% parent add visayas"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 2 [&aAklanon&f] Activated." to player
                    stop   
                       
                else if player has permission "ethnicity.slot-2.romblomanon":
                    execute console command "lp user %player% parent add romblomanon"
                    execute console command "lp user %player% parent add visayas"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 2 [&aRomblomanon&f] Activated." to player
                    stop      
                        
                    # SLOT 2 - MINDANAO ETHNICITIES                        
                    
                else if player has permission "ethnicity.slot-2.maguindanaon":
                    execute console command "lp user %player% parent add maguindanaon"
                    execute console command "lp user %player% parent add mindanao"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove visayas"
                    send "{@prefix}Slot 2 [&aMaguindanaon&f] Activated." to player
                    stop                 

                else if player has permission "ethnicity.slot-2.maranao":
                    execute console command "lp user %player% parent add maranao"
                    execute console command "lp user %player% parent add mindanao"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove visayas"
                    send "{@prefix}Slot 2 [&aMaranao&f] Activated." to player
                    stop    
                        
                else if player has permission "ethnicity.slot-2.tausug":
                    execute console command "lp user %player% parent add tausug"
                    execute console command "lp user %player% parent add mindanao"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove visayas"
                    send "{@prefix}Slot 2 [&aTausug&f] Activated." to player
                    stop    
                        
                else if player has permission "ethnicity.slot-2.badjao":
                    execute console command "lp user %player% parent add badjao"
                    execute console command "lp user %player% parent add mindanao"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove visayas"
                    send "{@prefix}Slot 2 [&aBadjao&f] Activated." to player
                    stop    
                       
                else if player has permission "ethnicity.slot-2.tagabawa":
                    execute console command "lp user %player% parent add tagabawa"
                    execute console command "lp user %player% parent add mindanao"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove visayas"     
                    send "{@prefix}Slot 2 [&aTagabawa&f] Activated." to player
                    



            if arg-2 is "3":
                if player has permission "kupal.membership":
                    loop {ethnicity::*}:
                        if player has permission "ethnicity.%loop-value%":
                            set {_active-slot} to loop-value                         
                            stop loop  
                        
                    execute console command "lp user %player% parent remove %{_active-slot}%"
                    execute console command "lp user %player% permission unset ethnicity.slot-1.active"
                    execute console command "lp user %player% permission unset ethnicity.slot-2.active"
                    execute console command "lp user %player% permission set ethnicity.slot-3.active true"
                    
                        # SLOT 3 - LUZON ETHNICITIES
                    
                    if player has permission "ethnicity.slot-3.tagalog":
                        execute console command "lp user %player% parent add tagalog"
                        execute console command "lp user %player% parent add luzon"
                        execute console command "lp user %player% parent remove visayas"
                        execute console command "lp user %player% parent remove mindanao"
                        send "{@prefix}Slot 3 [&aTagalog&f] Activated." to player
                        stop
                    
                    else if player has permission "ethnicity.slot-3.ilocano":
                        execute console command "lp user %player% parent add ilocano"
                        execute console command "lp user %player% parent add luzon"
                        execute console command "lp user %player% parent remove visayas"
                        execute console command "lp user %player% parent remove mindanao"
                        send "{@prefix}Slot 3 [&aIlocano&f] Activated." to player
                        stop
                      
                    else if player has permission "ethnicity.slot-3.bicolano":
