                                    execute console command "lp user %loop-player% permission unset ethnicity.slot-%{_slot}%.illonggo"
                                    execute console command "lp user %loop-player% permission unset ethnicity.slot-%{_slot}%.aklanon"
                                    execute console command "lp user %loop-player% permission unset ethnicity.slot-%{_slot}%.romblomanon"
