                        execute console command "lp user %player% parent remove luzon"
                        execute console command "lp user %player% parent remove mindanao"
                        send "{@prefix}Slot 3 [&aWaray&f] Activated." to player
                        stop   
                        
                    else if player has permission "ethnicity.slot-3.illonggo":
                        execute console command "lp user %player% parent add illonggo"
