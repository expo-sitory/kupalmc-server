                                    stop

                    set {playerEthnicity::%loop-player's uuid%} to {_current}


command /ethnicityslot [<text>] [<text>] [<text>]:
    trigger:
        if arg-1 is "reroll":
            wait 20 ticks
            if arg-2 is "1":              
                execute console command "lp user %player% permission settemp ethnicity.slot-1.rerolling true 20s"
                execute console command "ethnicity openfor %player% random_ethnicity"
                         
            else if arg-2 is "2":            
                if player has permission "ethnicity.slot-2.none":
                    execute console command "lp user %player% permission unset ethnicity.slot-2.none"   
                    execute console command "lp user %player% permission set ethnicity.slot-2.claimed true"

                execute console command "lp user %player% permission settemp ethnicity.slot-2.rerolling true 20s"
                wait 5 ticks
                execute console command "ethnicity openfor %player% random_ethnicity"                     
                stop
                                
            else if arg-2 is "3":
                if player has permission "kupal.membership":
                    if player has permission "ethnicity.slot-3.none":
                        execute console command "lp user %player% permission unset ethnicity.slot-3.none"     

                    execute console command "lp user %player% permission settemp ethnicity.slot-3.rerolling true 20s"
                    execute console command "ethnicity openfor %player% random_ethnicity"                                   
                stop   
            else:
                send "&cInvalid use of command" to player
                        
                        
        if arg-1 is "specific-reroll":
            wait 20 ticks
            if arg-2 is "1":                                
                if arg-3 is "luzon": 
                    execute console command "lp user %player% permission settemp ethnicity.slot-1.rerolling true 20s"
                    execute console command "ethnicity openfor %player% luzon-ethnicity"
                    
                else if arg-3 is "visayas":
                    execute console command "lp user %player% permission settemp ethnicity.slot-1.rerolling true 20s"
                    execute console command "ethnicity openfor %player% visayas-ethnicity"
                    stop
                    
                else if arg-3 is "mindanao":
                    execute console command "lp user %player% permission settemp ethnicity.slot-1.rerolling true 20s"
                    execute console command "ethnicity openfor %player% mindanao-ethnicity"
                    stop
                else:
                    send "&cInvalid use of command" to player                                             
                stop
                         
            else if arg-2 is "2":              
                if player has permission "ethnicity.slot-2.none":
                    execute console command "lp user %player% permission unset ethnicity.slot-2.none"   
                    execute console command "lp user %player% permission set ethnicity.slot-2.claimed true"

                if arg-3 is "luzon": 
                    execute console command "lp user %player% permission settemp ethnicity.slot-2.rerolling true 20s"
                    execute console command "ethnicity openfor %player% luzon-ethnicity"
                    
                else if arg-3 is "visayas":
                    execute console command "lp user %player% permission settemp ethnicity.slot-2.rerolling true 20s"
                    execute console command "ethnicity openfor %player% visayas-ethnicity"
                    stop
                    
                else if arg-3 is "mindanao":
                    execute console command "lp user %player% permission settemp ethnicity.slot-2.rerolling true 20s"
                    execute console command "ethnicity openfor %player% mindanao-ethnicity"
                    stop
                else:
                    send "&cInvalid use of command" to player                                             
                stop     

                                
            else if arg-2 is "3":                          
                if player has permission "kupal.membership":
                    if player does not have permission "ethnicity.slot-3.claimed":
                        execute console command "lp user %player% permission unset ethnicity.slot-3.none"                           

                if arg-3 is "luzon": 
                    execute console command "lp user %player% permission settemp ethnicity.slot-3.rerolling true 20s"
                    execute console command "ethnicity openfor %player% luzon-ethnicity"
                    
                else if arg-3 is "visayas":
                    execute console command "lp user %player% permission settemp ethnicity.slot-3.rerolling true 20s"
                    execute console command "ethnicity openfor %player% visayas-ethnicity"
                    stop
                    
                else if arg-3 is "mindanao":
                    execute console command "lp user %player% permission settemp ethnicity.slot-3.rerolling true 20s"
                    execute console command "ethnicity openfor %player% mindanao-ethnicity"
                    stop
                else:
                    send "&cInvalid use of command" to player                                             
                stop            
                    
                    
            
        if arg-1 is "select":
               
            if arg-2 is "1":  
                execute console command "lp user %player% permission settemp ethnicity.slot.cd true 5h"
                loop {ethnicity::*}:
                    if player has permission "ethnicity.%loop-value%":
                        set {_current} to loop-value                         
                        stop loop  
                
                execute console command "lp user %player% parent remove %{_current}%"
                execute console command "lp user %player% permission unset ethnicity.slot-2.active"
                execute console command "lp user %player% permission unset ethnicity.slot-3.active"
                execute console command "lp user %player% permission set ethnicity.slot-1.active true"
                
                
                    
                    # SLOT 1 - LUZON ETHNICITIES
                    
                if player has permission "ethnicity.slot-1.tagalog":
                    execute console command "lp user %player% parent add tagalog"
                    execute console command "lp user %player% parent add luzon"
                    execute console command "lp user %player% parent remove visayas"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 1 [&aTagalog&f] Activated." to player
                    stop
                    
                else if player has permission "ethnicity.slot-1.ilocano":
                    execute console command "lp user %player% parent add ilocano"
                    execute console command "lp user %player% parent add luzon"
                    execute console command "lp user %player% parent remove visayas"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 1 [&aIlocano&f] Activated." to player
                    stop
                      
                else if player has permission "ethnicity.slot-1.bicolano":
                    execute console command "lp user %player% parent add bicolano"
                    execute console command "lp user %player% parent add luzon"
                    execute console command "lp user %player% parent remove visayas"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 1 [&aBicolano&f] Activated." to player
                    stop
                        
                else if player has permission "ethnicity.slot-1.kapampangan":
                    execute console command "lp user %player% parent add kapampangan"
                    execute console command "lp user %player% parent add luzon"
                    execute console command "lp user %player% parent remove visayas"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 1 [&aKapampangan&f] Activated." to player
                    stop

                else if player has permission "ethnicity.slot-1.igorot":
                    execute console command "lp user %player% parent add igorot"
                    execute console command "lp user %player% parent add luzon"
                    execute console command "lp user %player% parent remove visayas"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 1 [&aIgorot&f] Activated." to player
                    stop                        
                        
                    # SLOT 1 - VISAYAS ETHNICITIES
                    
                else if player has permission "ethnicity.slot-1.cebuano":
                    execute console command "lp user %player% parent add cebuano"
                    execute console command "lp user %player% parent add visayas"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 1 [&aCebuano&f] Activated." to player
                    stop          
                        
                else if player has permission "ethnicity.slot-1.waray":
                    execute console command "lp user %player% parent add waray"
                    execute console command "lp user %player% parent add visayas"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 1 [&aWaray&f] Activated." to player
                    stop   
                        
                else if player has permission "ethnicity.slot-1.illonggo":
                    execute console command "lp user %player% parent add illonggo"
                    execute console command "lp user %player% parent add visayas"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 1 [&aIllonggo&f] Activated." to player
                    stop   
                      
                else if player has permission "ethnicity.slot-1.aklanon":
                    execute console command "lp user %player% parent add aklanon"
                    execute console command "lp user %player% parent add visayas"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 1 [&aAklanon&f] Activated." to player
                    stop   
                       
                else if player has permission "ethnicity.slot-1.romblomanon":
                    execute console command "lp user %player% parent add romblomanon"
                    execute console command "lp user %player% parent add visayas"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove mindanao"
                    send "{@prefix}Slot 1 [&aRomblomanon&f] Activated." to player
                    stop      
                        
                    # SLOT 1 - MINDANAO ETHNICITIES                        
                    
                else if player has permission "ethnicity.slot-1.maguindanaon":
                    execute console command "lp user %player% parent add maguindanaon"
                    execute console command "lp user %player% parent add mindanao"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove visayas"
                    send "{@prefix}Slot 1 [&aMaguindanaon&f] Activated." to player
                    stop                 

                else if player has permission "ethnicity.slot-1.maranao":
                    execute console command "lp user %player% parent add maranao"
                    execute console command "lp user %player% parent add mindanao"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove visayas"
                    send "{@prefix}Slot 1 [&aMaranao&f] Activated." to player
                    stop    
                        
                else if player has permission "ethnicity.slot-1.tausug":
                    execute console command "lp user %player% parent add tausug"
                    execute console command "lp user %player% parent add mindanao"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove visayas"
                    send "{@prefix}Slot 1 [&aTausug&f] Activated." to player
                    stop    
                        
                else if player has permission "ethnicity.slot-1.badjao":
                    execute console command "lp user %player% parent add badjao"
                    execute console command "lp user %player% parent add mindanao"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove visayas"
                    send "{@prefix}Slot 1 [&aBadjao&f] Activated." to player
                    stop    
                       
                else if player has permission "ethnicity.slot-1.tagabawa":
                    execute console command "lp user %player% parent add tagabawa"
                    execute console command "lp user %player% parent add mindanao"
                    execute console command "lp user %player% parent remove luzon"
                    execute console command "lp user %player% parent remove visayas"    
                    send "{@prefix}Slot 1 [&aTagabawa&f] Activated." to player
                
            if arg-2 is "2":
                loop {ethnicity::*}:
                    if player has permission "ethnicity.%loop-value%":
                        set {_current-slot} to loop-value                         
                        stop loop  
                        
                execute console command "lp user %player% parent remove %{_current-slot}%"
                execute console command "lp user %player% permission unset ethnicity.slot-1.active"
                execute console command "lp user %player% permission unset ethnicity.slot-3.active"
                execute console command "lp user %player% permission set ethnicity.slot-2.active true"
                    
                    # SLOT 2 - LUZON ETHNICITIES
                    
                if player has permission "ethnicity.slot-2.tagalog":
                    execute console command "lp user %player% parent add tagalog"
                    execute console command "lp user %player% parent add luzon"
                    execute console command "lp user %player% parent remove visayas"
                    execute console command "lp user %player% parent remove mindanao"
