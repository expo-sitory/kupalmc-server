                        execute console command "lp user %player% parent remove visayas"
                        execute console command "lp user %player% parent remove mindanao"
                        send "{@prefix}Slot 3 [&aIgorot&f] Activated." to player
                        stop                        
                        
                        # SLOT 3 - VISAYAS ETHNICITIES
                        
                    else if player has permission "ethnicity.slot-3.cebuano":
                        execute console command "lp user %player% parent add cebuano"
                        execute console command "lp user %player% parent add visayas"
                        execute console command "lp user %player% parent remove luzon"
                        execute console command "lp user %player% parent remove mindanao"
                        send "{@prefix}Slot 3 [&aCebuano&f] Activated." to player
                        stop          
                        
                    else if player has permission "ethnicity.slot-3.waray":
